# Stripe Configuration (keys stored in SSM, not env vars)
# Set up via: aws ssm put-parameter --name /tradequt/stripeSecretKey --value sk_test_xxx --type SecureString
# Webhook secret: aws ssm put-parameter --name /tradequt/stripeWebhookSecret --value whsec_xxx --type SecureString

# AWS Configuration (for local testing with SAM)
AWS_REGION=us-east-1

# DynamoDB Tables (for local testing)
TRADES_TABLE=trading-journal-trades-dev
TRADE_STATS_TABLE=trading-journal-stats-dev
ACCOUNTS_TABLE=trading-journal-accounts-dev
GOALS_TABLE=trading-journal-goals-dev
RULES_TABLE=trading-journal-rules-dev
USER_PREFERENCES_TABLE=trading-journal-preferences-dev
SAVED_OPTIONS_TABLE=trading-journal-saved-options-dev
SUBSCRIPTIONS_TABLE=trading-journal-subscriptions-dev
RATE_LIMIT_TABLE=trading-journal-rate-limit-dev

# S3 Bucket
IMAGES_BUCKET=trading-journal-images-dev

# Cognito
USER_POOL_ID=us-east-1_xxxxxxxxx
USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API (for AI features)
GEMINI_API_KEY=your_gemini_api_key_here
