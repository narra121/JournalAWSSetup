{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "error-report.schema.json",
  "type": "object",
  "required": ["error", "timestamp", "url"],
  "additionalProperties": false,
  "properties": {
    "error": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" },
        "stack": { "type": ["string", "null"] },
        "componentStack": { "type": ["string", "null"] },
        "type": { "type": "string", "enum": ["react-render", "unhandled-error", "unhandled-rejection", "manual"] }
      },
      "additionalProperties": false
    },
    "timestamp": { "type": "string" },
    "url": { "type": "string" },
    "userId": { "type": ["string", "null"] },
    "browser": {
      "type": "object",
      "properties": {
        "userAgent": { "type": "string" },
        "language": { "type": "string" },
        "platform": { "type": "string" },
        "screenWidth": { "type": "integer" },
        "screenHeight": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "consoleLogs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": { "type": "string" },
          "message": { "type": "string" },
          "timestamp": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "recentApiCalls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "method": { "type": "string" },
          "status": { "type": "integer" },
          "timestamp": { "type": "string" },
          "requestBody": { "type": ["string", "null"] },
          "responseBody": { "type": ["string", "null"] },
          "durationMs": { "type": "integer" },
          "curl": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "appVersion": { "type": ["string", "null"] },
        "sessionDuration": { "type": "integer" }
      },
      "additionalProperties": true
    }
  }
}
